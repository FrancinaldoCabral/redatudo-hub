# Application Environment
NODE_ENV=production

# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=your_secure_mongo_password_here
MONGO_DB_NAME=redatudo

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Replicate Configuration
REPLICATE_API_TOKEN=r8_your-replicate-token-here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Convertio API
CONVERTIO_API_KEY=your-convertio-api-key-here

# API URL (for frontend)
API_URL=http://api:5000

# Google Tag Manager (optional)
GTM_ID=GTM-XXXXXXX

# WooCommerce Webhook (if applicable)
WOO_WEBHOOK_SECRET=your-woo-webhook-secret-here
